---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Connect with Us — Tango Garden"
  description="Get in touch with Tango Garden Cologne. Find us on WhatsApp, email or visit us at Thürmchenswall 21."
  canonical="https://tangogarden.de/pages/contact"
>
  <Fragment set:html={`
<!-- HERO -->
<section class="contact-hero">
  <h1>Connect with us.</h1>
  <p>Questions? We're here to help you find your way into the Garden.</p>
</section>

<!-- THREE CARDS -->
<section class="contact-cards-section">
  <div class="contact-cards-inner">

    <div class="contact-card contact-card--whatsapp">
      <div class="contact-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="26" height="26" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </div>
      <h2>WhatsApp</h2>
      <p>The fastest way to get a human response. Usually under 2 hours.</p>
      <a href="https://wa.me/491602368723?text=Hi!%20I'm%20nervous%20but%20interested..." target="_blank" rel="noopener" class="contact-card-btn contact-card-btn--green">Message the Garden</a>
    </div>

    <div class="contact-card">
      <div class="contact-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="26" height="26" fill="#4E5D22"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
      </div>
      <h2>Email</h2>
      <p>For the long-form thinkers and detail-oriented inquiries.</p>
      <a href="mailto:hello@tangogarden.de" class="contact-card-btn contact-card-btn--outline">hello@tangogarden.de</a>
    </div>

    <div class="contact-card">
      <div class="contact-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="26" height="26" fill="#4E5D22"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      </div>
      <h2>Location</h2>
      <p>This is where you will find us during our classes and events.</p>
      <a href="#location" class="contact-card-btn contact-card-btn--outline">Get Directions ↓</a>
    </div>

  </div>
</section>

<!-- MAP + LOCATION DETAILS -->
<section class="contact-location-section" id="location">
  <div class="contact-location-inner">
    <div class="contact-map">
      <iframe
        src="https://maps.google.com/maps?q=Th%C3%BCrmchenswall+21%2C+50668+K%C3%B6ln%2C+Germany&t=&z=16&ie=UTF8&iwloc=B&output=embed"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Tango Garden Cologne location">
      </iframe>
    </div>
    <div class="contact-location-details">
      <h2>Tango Garden Cologne</h2>
      <p class="address">Thürmchenswall 21, 50668 Cologne</p>
      <p class="studio-name">(Yoga Drop Studio)</p>
      <div class="contact-transport-label">Public Transport</div>
      <ul class="contact-transport-list">
        <li><span class="icon">🚊</span> <span>Trams <strong>12, 15, 16, 18</strong> to Ebertplatz (3 min walk)</span></li>
        <li><span class="icon">🚌</span> <span>Buses <strong>127, 140</strong> to Ebertplatz</span></li>
        <li><span class="icon">🚲</span> <span>Bike: Plenty of racks right at Ebertplatz</span></li>
      </ul>
      <div class="contact-rule-box">
        <strong>The "First 10 Minutes" Rule:</strong>
        <p>Arrive 10 minutes early to change and settle in without the rush.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="contact-faq-section">
  <div class="contact-faq-inner">
    <div class="contact-faq-eyebrow">Common Questions</div>
    <h2>Everything You're Wondering</h2>
    <p class="faq-subtitle">No question is too small. Here are the ones we hear most.</p>

    <div class="faq-item">
      <button class="faq-question">Do I need any dance experience to start?</button>
      <div class="faq-answer">Not at all. Every session is designed for absolute beginners. We start from scratch — how to stand, how to be present, how to listen through touch. No prior dance experience is needed or expected.</div>
    </div>
    <div class="faq-item">
      <button class="faq-question">Do I need to bring a partner?</button>
      <div class="faq-answer">No. Most people come alone. We rotate partners during class so everyone gets to dance with different people. In fact, coming solo often makes it easier to connect with the community.</div>
    </div>
    <div class="faq-item">
      <button class="faq-question">What should I wear?</button>
      <div class="faq-answer">Comfortable clothes you can move in. For shoes, we recommend either a clean pair of cozy socks, or a second pair of indoor shoes. Avoid thick rubber soles — they grip the floor and make turning difficult.</div>
    </div>
    <div class="faq-item">
      <button class="faq-question">Is the class taught in English?</button>
      <div class="faq-answer">Yes. All teaching is in English. Under request, we can also offer German, Russian and Greek. The deeper language of tango — presence, touch, listening — transcends words entirely.</div>
    </div>
    <div class="faq-item">
      <button class="faq-question">What's the difference between the three options?</button>
      <div class="faq-answer">"Enter the Garden" is a one-time introductory event — the easiest way to try tango with no commitment. "Regular Classes" are multi-week courses where you actually learn. "Garden Practica" are open weekly practice sessions for those who want to keep dancing between courses.</div>
    </div>
    <div class="faq-item">
      <button class="faq-question">What if I miss a class?</button>
      <div class="faq-answer">No worries. Students on the multi-week course pass can cover any missed class by attending our Garden Practica during the pass' eligibility cycle, at no extra cost.</div>
    </div>
    <div class="faq-item">
      <button class="faq-question">I'm shy. Will I feel awkward?</button>
      <div class="faq-answer">Probably a little — that's normal. Most people feel that way in the first 20 minutes. Then something shifts. Tango is one of the few spaces where being present and quiet is actually an advantage.</div>
    </div>
    <div class="faq-item">
      <button class="faq-question">Where exactly are you located in Cologne?</button>
      <div class="faq-answer">We're at Thürmchenswall 21, 50668 Cologne — inside the Yoga Drop Studio. It's a 3-minute walk from Ebertplatz, reachable by trams 12, 15, 16, 18 or buses 127 and 140.</div>
    </div>

  </div>
</section>
`} />
</BaseLayout>

<style is:global>
/* Hero */
    .contact-hero {
      background: var(--cream);
      padding: 7rem 1.5rem 4rem;
      text-align: center;
    }
    .contact-hero h1 {
      font-size: clamp(2.4rem, 7vw, 3.8rem);
      font-weight: 700;
      color: var(--green);
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }
    .contact-hero p {
      font-size: 1.1rem;
      color: var(--text-mid);
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.6;
    }

    /* Three cards */
    .contact-cards-section {
      background: var(--cream);
      padding: 2rem 1.5rem 5rem;
    }
    .contact-cards-inner {
      max-width: 920px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    @media (max-width: 680px) {
      .contact-cards-inner { grid-template-columns: 1fr; }
    }
    .contact-card {
      background: #fff;
      border-radius: 14px;
      border: 1px solid rgba(0,0,0,0.08);
      padding: 2.25rem 1.75rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }
    .contact-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.1);
    }
    .contact-card-icon {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: var(--cream);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.1rem;
    }
    .contact-card h2 {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--green);
      margin-bottom: 0.6rem;
    }
    .contact-card p {
      font-size: 0.9rem;
      color: var(--text-light);
      line-height: 1.6;
      flex: 1;
      margin-bottom: 1.5rem;
    }
    .contact-card-btn {
      display: inline-block;
      padding: 0.65rem 1.5rem;
      border-radius: 50px;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      background: #fff;
      border: 1.5px solid var(--green);
      color: var(--green);
      transition: background 0.2s ease, color 0.2s ease;
    }
    .contact-card-btn:hover {
      background: var(--green);
      color: #fff;
    }

    /* Map + location */
    .contact-location-section {
      background: #fff;
      padding: 5rem 1.5rem;
    }
    .contact-location-inner {
      max-width: 1060px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }
    @media (max-width: 720px) {
      .contact-location-inner { grid-template-columns: 1fr; }
    }
    .contact-map iframe {
      width: 100%;
      height: 340px;
      border-radius: 12px;
      border: none;
      display: block;
    }
    .contact-location-details h2 {
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--green);
      margin-bottom: 0.5rem;
    }
    .contact-location-details .address {
      font-size: 1rem;
      color: var(--text-mid);
      margin-bottom: 0.25rem;
    }
    .contact-location-details .studio-name {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-mid);
      margin-bottom: 1.75rem;
    }
    .contact-transport-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 600;
      color: var(--text-light);
      margin-bottom: 0.75rem;
    }
    .contact-transport-list {
      list-style: none;
      padding: 0;
      margin: 0 0 1.75rem;
    }
    .contact-transport-list li {
      font-size: 0.95rem;
      color: var(--text-mid);
      padding: 0.3rem 0;
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .contact-transport-list li span.icon { flex-shrink: 0; }
    .contact-rule-box {
      background: var(--cream);
      border-left: 4px solid var(--green);
      border-radius: 6px;
      padding: 1rem 1.25rem;
    }
    .contact-rule-box strong {
      font-size: 0.9rem;
      color: var(--green);
      display: block;
      margin-bottom: 0.3rem;
    }
    .contact-rule-box p {
      font-size: 0.88rem;
      color: var(--text-mid);
      line-height: 1.55;
      margin: 0;
    }

    /* FAQ */
    .contact-faq-section {
      background: var(--cream);
      padding: 5rem 1.5rem 6rem;
    }
    .contact-faq-inner {
      max-width: 760px;
      margin: 0 auto;
    }
    .contact-faq-eyebrow {
      text-align: center;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 600;
      color: var(--green);
      margin-bottom: 0.75rem;
    }
    .contact-faq-inner h2 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--green);
      text-align: center;
      margin-bottom: 0.6rem;
    }
    .contact-faq-inner .faq-subtitle {
      text-align: center;
      font-size: 1rem;
      color: var(--text-light);
      margin-bottom: 3rem;
    }
    .faq-item {
      border-bottom: 1px solid rgba(0,0,0,0.1);
      background: #fff;
    }
    .faq-item:first-of-type { border-top: 1px solid rgba(0,0,0,0.1); }
    .faq-question {
      width: 100%;
      background: none;
      border: none;
      text-align: left;
      padding: 1.2rem 1.25rem;
      font-size: 1rem;
      font-weight: 600;
      color: var(--green);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }
    .faq-question::after {
      content: '+';
      font-size: 1.4rem;
      font-weight: 300;
      color: var(--green);
      flex-shrink: 0;
      transition: transform 0.2s ease;
    }
    .faq-item.is-open .faq-question::after { transform: rotate(45deg); }
    .faq-answer {
      display: none;
      padding: 0 1.25rem 1.25rem;
      font-size: 0.97rem;
      color: var(--text-mid);
      line-height: 1.75;
    }
    .faq-item.is-open .faq-answer { display: block; }
</style>

<script>
  // Contact-page FAQ accordion. In the pre-Astro HTML this lived in the same
  // <script> tag as the nav drawer IIFE, so the migration dropped it along with
  // the nav code — leaving every answer permanently collapsed.
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.faq-question')) {
    // The markup ships without these, so a screen reader would announce a
    // plain button with no hint that it expands anything.
    btn.setAttribute('aria-expanded', 'false');

    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      if (!item) return;
      const wasOpen = item.classList.contains('is-open');

      for (const open of document.querySelectorAll('.faq-item.is-open')) {
        open.classList.remove('is-open');
        open.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
      }

      if (!wasOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  }
</script>
