---
import { navItems, social } from '../data/nav.js';
import Icon from './Icons.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCurrent = (href: string) => path === href.replace(/\/$/, '');
---

<nav class="site-nav">
  <div class="nav-container">
    <a href="/" class="nav-logo" aria-label="Tango Garden — Home">
      <span class="nav-logo-desktop"
        ><img src="/assets/logo-icon.svg" alt="" width="32" height="32" loading="eager" /><span
          class="nav-logo-text">Tango Garden</span
        ></span
      >
      <span class="nav-logo-mobile"
        ><img
          src="/images/logo-stacked-green.svg"
          alt="Tango Garden"
          width="100"
          height="40"
          loading="eager"
        /></span
      >
    </a>
    <button
      class="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-drawer"><span></span><span></span><span></span></button
    >
    <ul class="nav-links" role="list">
      {
        navItems.map((item) =>
          item.children ? (
            <li class="nav-item-has-dropdown">
              <a
                href={item.href}
                class="nav-link"
                aria-current={isCurrent(item.href) ? 'page' : undefined}
              >
                {item.label}{' '}
                <span class="nav-caret" aria-hidden="true">
                  <svg viewBox="0 0 10 6" width="10" height="6" fill="none">
                    <path
                      fill="currentColor"
                      fill-rule="evenodd"
                      d="M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 0 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              </a>
              <ul class="nav-dropdown" role="list">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href}>{child.label}</a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class="nav-link"
                aria-current={isCurrent(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          )
        )
      }
    </ul>
    <div class="nav-social">
      <a
        href={social.facebook}
        target="_blank"
        rel="noopener"
        class="nav-social-link"
        aria-label="Facebook"><Icon name="facebook" /></a
      >
      <a
        href={social.instagram}
        target="_blank"
        rel="noopener"
        class="nav-social-link"
        aria-label="Instagram"><Icon name="instagram" /></a
      >
    </div>
  </div>

  <!-- `inert` keeps the off-canvas links out of the tab order while closed;
       aria-hidden alone left them focusable. -->
  <div class="nav-drawer" id="nav-drawer" aria-hidden="true" inert>
    <button class="nav-drawer-close" aria-label="Close menu">&#x2715;</button>
    <ul class="nav-drawer-links" role="list">
      {
        navItems.map((item) => (
          <li>
            {item.children ? (
              <details class="nav-drawer-detail">
                <summary class="nav-drawer-summary">{item.label}</summary>
                <ul class="nav-drawer-submenu" role="list">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a href={item.href}>{item.label}</a>
            )}
          </li>
        ))
      }
    </ul>
    <div class="nav-drawer-footer">
      <p class="nav-drawer-connect">Connect with us</p>
      <div class="nav-drawer-social">
        <a href={social.facebook} target="_blank" rel="noopener" aria-label="Facebook"
          ><Icon name="facebook" size={24} /></a
        >
        <a href={social.instagram} target="_blank" rel="noopener" aria-label="Instagram"
          ><Icon name="instagram" size={24} /></a
        >
        <a href={social.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp"
          ><Icon name="whatsapp" size={24} /></a
        >
      </div>
    </div>
  </div>
  <div class="nav-overlay" id="nav-overlay"></div>
</nav>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const drawer = document.getElementById('nav-drawer');
  const overlay = document.getElementById('nav-overlay');
  const closeBtn = document.querySelector<HTMLButtonElement>('.nav-drawer-close');

  if (toggle && drawer) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      drawer.setAttribute('aria-hidden', String(!open));
      drawer.toggleAttribute('inert', !open);
      drawer.classList.toggle('is-open', open);
      overlay?.classList.toggle('is-visible', open);
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () =>
      setOpen(toggle.getAttribute('aria-expanded') !== 'true')
    );
    closeBtn?.addEventListener('click', () => setOpen(false));
    overlay?.addEventListener('click', () => setOpen(false));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) setOpen(false);
    });
  }
</script>
