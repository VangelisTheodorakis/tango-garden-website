---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
  noindex?: boolean;
}

/**
 * One canonical shape for the whole site: no trailing slash (except the root).
 * That is how the URLs are indexed today, it is what the sitemap emits, and it
 * is what the host serves directly — so a canonical never points at a redirect.
 */
const canonicalPath = Astro.url.pathname.replace(/(.)\/$/, '$1');

const {
  title,
  description,
  canonical = new URL(canonicalPath, Astro.site ?? Astro.url).href,
  ogImage = new URL('/images/og-image.jpg', Astro.site ?? Astro.url).href,
  ogType = 'website',
  noindex = false,
} = Astro.props;
---

<title>{title}</title>
<meta name="description" content={description} />
{/* noindex without nofollow: these pages should still pass link equity on. */}
{noindex && <meta name="robots" content="noindex" />}
<link rel="canonical" href={canonical} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/assets/logo-icon.svg" />

<!-- Open Graph -->
<meta property="og:site_name" content="Tango Garden" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:type" content={ogType} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
