---
import { products } from '../data/products.js';

// Only the products that are live on the store are listed.
const live = products.filter((p) => !p.hidden);

// Group the passes so the page reads as three offerings rather than eight SKUs.
const groups = [
  {
    title: 'Enter the Garden',
    blurb: 'One-time event for those who want to try without commitment.',
    match: (h: string) => h.startsWith('enter-the-garden'),
  },
  {
    title: 'The Sprouting Sessions',
    blurb: 'Beginner course passes — one class, four classes, or the full course.',
    match: (h: string) => h.startsWith('the-sprouting-sessions'),
  },
  {
    title: 'The Garden Practica',
    blurb: 'Open-level guided practice sessions. Drop in whenever you like.',
    match: (h: string) => h.startsWith('the-garden-practica'),
  },
].map((g) => ({ ...g, items: live.filter((p) => g.match(p.handle)) }))
  .filter((g) => g.items.length > 0);
---

<section class="page-hero">
  <h1 class="section-title">Classes &amp; Passes</h1>
  <p class="section-subtitle">
    Every way into the Garden, with current prices. Not sure which fits? Just ask us.
  </p>
</section>

<div class="collection">
  {
    groups.map((group) => (
      <section class="collection-group">
        <h2>{group.title}</h2>
        <p class="collection-blurb">{group.blurb}</p>
        <ul class="collection-list" role="list">
          {group.items.map((product) => (
            <li>
              <a class="collection-card" href={`/products/${product.handle}`}>
                <span class="collection-card-title">{product.heading ?? product.title}</span>
                <span class="collection-card-price">{product.price}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }

  <p class="collection-note">* for students and anyone who is 28 years old or less</p>

  <div class="collection-help">
    <h2>Not sure where to start?</h2>
    <p>Tell us where you are and we will point you to the right pass.</p>
    <a
      class="btn-whatsapp"
      href="https://wa.me/491602368723?text=Hi!%20I'm%20not%20sure%20which%20option%20is%20right%20for%20me..."
      target="_blank"
      rel="noopener">💬 Chat on WhatsApp</a
    >
  </div>
</div>

<style>
  .page-hero {
    background: var(--cream);
    padding: 60px 20px 50px;
    text-align: center;
  }
  .collection {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px;
  }
  .collection-group + .collection-group {
    margin-top: 50px;
  }
  .collection-group h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--green);
    margin-bottom: 0.4rem;
  }
  .collection-blurb {
    color: var(--text-light);
    margin-bottom: 1.25rem;
  }
  .collection-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 750px) {
    .collection-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .collection-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--cream);
    border: 2px solid transparent;
    border-radius: 12px;
    padding: 18px 20px;
    text-decoration: none;
    color: var(--text);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .collection-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(45, 80, 22, 0.15);
    border-color: var(--green);
  }
  .collection-card-title {
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .collection-card-price {
    font-weight: 700;
    color: var(--green);
    white-space: nowrap;
  }
  .collection-note {
    margin-top: 40px;
    text-align: center;
    color: var(--text-light);
    font-size: 0.9rem;
  }
  .collection-help {
    margin-top: 40px;
    padding: 50px 30px;
    background: var(--cream-light);
    border: 1px solid rgba(45, 80, 22, 0.1);
    border-radius: 20px;
    text-align: center;
  }
  .collection-help h2 {
    font-size: 1.4rem;
    color: var(--green);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .collection-help p {
    color: var(--text-light);
    margin-bottom: 1.5rem;
  }
</style>
