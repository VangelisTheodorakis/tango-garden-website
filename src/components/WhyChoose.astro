---
const features = [
  ['No Partner Needed', 'We make sure that our classes are role balanced.'],
  ['Welcome Circle', 'In every class we explore our expectations and goals.'],
  ['Garden Ambassadors', "Someone will greet you — you'll never stand alone"],
  ['Group meetups', 'Make real connections over food and common interests'],
  ['Boundaries Respected', 'Always, no exceptions — your comfort is non-negotiable'],
  ['Your Choice of Role', 'Lead, follow, or both — you decide, not your gender'],
];
---

<section id="why-choose-garden" style="background: white; padding: 60px 20px;">
  <div class="container" style="max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 60px;">
      <div
        style="font-size: 14px; text-transform: uppercase; letter-spacing: 2px; color: #4E5D22; font-weight: 600; margin-bottom: 20px;"
      >
        What Makes Us Different
      </div>
      <h2
        style="font-size: 42px; font-weight: 700; color: #4E5D22; margin-bottom: 30px; line-height: 1.2;"
      >
        Why People Choose This Garden
      </h2>
      <p style="font-size: 20px; color: #666; max-width: 700px; margin: 0 auto; line-height: 1.6;">
        Not about perfection. About finding your people through tango.
      </p>
    </div>

    <div class="features-grid">
      {
        features.map(([title, body]) => (
          <div class="feature-item">
            <div class="feature-check" aria-hidden="true">✓</div>
            <div>
              <h3 style="font-size: 20px; color: #4E5D22; margin-bottom: 8px; font-weight: 700;">
                {title}
              </h3>
              <p style="font-size: 16px; line-height: 1.6; color: #666; margin: 0;">{body}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="bottom-cta-container">
      <h3 style="font-size: 28px; margin-bottom: 20px; font-weight: 700;">Want to Know More?</h3>
      <a href="/pages/the-garden" class="pathway-style-button">
        <p style="font-size: 18px; line-height: 1.7; margin: 20px 20px;">
          Read about the stories, the people and experiences that shaped Tango Garden.
        </p>
      </a>
    </div>
  </div>
</section>
